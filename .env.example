# Required: Your Auth0 tenant domain (no https:// prefix)
MCP_USE_OAUTH_AUTH0_DOMAIN=your-tenant.us.auth0.com

# Required: API audience — must match the API identifier you create in Auth0
MCP_USE_OAUTH_AUTH0_AUDIENCE=http://localhost:3000/

# Optional: Server port (defaults to 3000)
# PORT=3000

# Optional: Base URL for OAuth redirects
# BASE_URL=http://localhost:3000

# Optional: Toggle JWT verification (defaults to true). Never disable in production.
# VERIFY_JWT=true
